<odoo>
    <record id="view_payment_provider_pagarme_form" model="ir.ui.view">
        <field name="name">payment.provider.pagarme.form</field>
        <field name="model">payment.provider</field>
        <field name="inherit_id" ref="payment.payment_provider_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group" position="inside">
                <group string="Pagar.me Configuration">
                    <field name="pagarme_api_key"/>
                    <field name="pagarme_encryption_key"/>
                    <field name="pagarme_test_mode"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
