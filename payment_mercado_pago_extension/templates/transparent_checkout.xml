<odoo>
    <template id="mercado_pago_transparent_checkout" inherit_id="payment.checkout_form">
        <xpath expr="//form" position="inside">
            <div id="mercado_pago_checkout" class="d-none" t-att-data-acquirer-id="acquirer.id">
                <!-- Mercado Pago Transparent Checkout widget will be loaded here -->
                <div class="row">
                    <div class="col-12">
                        <h5>Pagar com Mercado Pago</h5>
                    </div>
                </div>
                <div id="mercado-pago-form-container">
                    <!-- Form fields will be dynamically generated by JavaScript -->
                </div>
                <div id="mercado-pago-loading" class="text-center" style="display:none;">
                    <i class="fa fa-spinner fa-spin"></i> Processando pagamento...
                </div>
            </div>
        </xpath>
        <xpath expr="//script[last()]" position="after">
            <script src="https://sdk.mercadopago.com/js/v2"></script>
            <script type="text/javascript">
                // Make Mercado Pago public key available to frontend JavaScript
                <t t-foreach="acquirers" t-as="acquirer">
                    <t t-if="acquirer.provider == 'mercado_pago'">
                        window.odoo_mercado_pago_public_key = '<t t-esc="acquirer.mercado_pago_public_key"/>';
                    </t>
                </t>
            </script>
        </xpath>
    </template>
</odoo>