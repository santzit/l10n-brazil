<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Stone/Pagar.me Payment Provider Data -->
    <record id="payment_provider_stone_pagarme" model="payment.provider">
        <field name="name">Stone/Pagar.me</field>
        <field name="code">stone_pagarme</field>
        <field name="company_id" ref="base.main_company"/>
        <field name="state">disabled</field>
        <field name="is_published">False</field>
        <field name="payment_icon_ids" eval="[(6, 0, [
            ref('payment.payment_icon_cc_visa'),
            ref('payment.payment_icon_cc_mastercard'),
            ref('payment.payment_icon_cc_discover'),
            ref('payment.payment_icon_cc_diners'),
            ref('payment.payment_icon_cc_jcb'),
            ref('payment.payment_icon_cc_amex')
        ])]"/>
        <field name="supported_currency_ids" eval="[(6, 0, [ref('base.BRL')])]"/>
        <field name="capture_manually">False</field>
        <field name="allow_tokenization">False</field>
        <field name="allow_express_checkout">False</field>
        <field name="redirect_form_view_id" ref="stone_pagarme_payment.stone_pagarme_redirect_form"/>
        <field name="inline_form_view_id" ref="stone_pagarme_payment.stone_pagarme_inline_form"/>
    </record>

</odoo>