<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Pagar.me Payment Provider Views -->
    
    <!-- Payment Provider Form View Extension -->
    <record id="payment_provider_form_pagarme" model="ir.ui.view">
        <field name="name">payment.provider.form.pagarme</field>
        <field name="model">payment.provider</field>
        <field name="inherit_id" ref="payment.payment_provider_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='provider_details']" position="after">
                <group attrs="{'invisible': [('code', '!=', 'pagarme')]}" string="Pagar.me Configuration">
                    <field name="pagarme_api_key" password="True"/>
                    <field name="pagarme_encryption_key" password="True"/>
                    <field name="pagarme_webhook_url" readonly="1"/>
                    <field name="pagarme_max_installments"/>
                    <field name="pagarme_min_installment_amount"/>
                </group>
            </xpath>
        </field>
    </record>

</odoo>