<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Payment Acquirer Form View -->
    <record id="view_acquirer_form" model="ir.ui.view">
        <field name="name">payment.acquirer.form.pagarme</field>
        <field name="model">payment.acquirer</field>
        <field name="inherit_id" ref="payment.acquirer_form"/>
        <field name="arch" type="xml">
            <xpath expr='//group[@name="acquirer"]' position='after'>
                <group attrs="{'invisible': [('provider', '!=', 'pagarme')]}">
                    <group name="pagarme_credentials" string="Credentials">
                        <field name="pagarme_app_id" password="True" placeholder="pk_test_..."/>
                        <field name="pagarme_api_key" password="True" placeholder="sk_test_..."/>
                    </group>
                    <group name="pagarme_configuration" string="Configuration">
                        <field name="pagarme_webhook_url" readonly="1"/>
                        <button name="test_connection" string="Test Connection" type="object" 
                                class="btn-secondary"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>

    <!-- Payment Transaction Form View -->
    <record id="view_transaction_form" model="ir.ui.view">
        <field name="name">payment.transaction.form.pagarme</field>
        <field name="model">payment.transaction</field>
        <field name="inherit_id" ref="payment.transaction_form"/>
        <field name="arch" type="xml">
            <xpath expr='//group[@name="acquirer_reference"]' position='after'>
                <group attrs="{'invisible': [('provider', '!=', 'pagarme')]}" 
                       string="Pagar.me Details">
                    <field name="pagarme_token"/>
                    <field name="pagarme_order_id"/>
                    <field name="pagarme_charge_id"/>
                </group>
            </xpath>
        </field>
    </record>

</odoo>