<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Payment Acquirer Configuration View -->
    <record id="payment_acquirer_form_pagarme" model="ir.ui.view">
        <field name="name">payment.acquirer.form.pagarme</field>
        <field name="model">payment.acquirer</field>
        <field name="inherit_id" ref="payment.payment_acquirer_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='acquirer']" position="after">
                <group attrs="{'invisible': [('provider', '!=', 'pagarme')]}" string="Pagar.me Credentials">
                    <field name="pagarme_app_id" password="True"/>
                    <field name="pagarme_api_key" password="True"/>
                </group>
            </xpath>
        </field>
    </record>

</odoo>