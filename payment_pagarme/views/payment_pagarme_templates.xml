<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Note: For Pagar.me redirect checkout, inline form is not needed -->
    <!-- Payment is processed via redirect to Pagar.me's secure checkout page -->
    <template id="inline_form" name="Pagar.me Inline Form (Not Used for Redirect)">
        <div class="o_pagarme_payment_form">
            <div class="alert alert-info">
                <strong>Pagamento Seguro via Pagar.me</strong><br/>
                Você será redirecionado para completar o pagamento de forma segura no Pagar.me.
            </div>
        </div>
    </template>

    <template id="redirect_form" name="Pagar.me Redirect Form">
        <div class="o_pagarme_redirect_form">
            <div class="text-center">
                <h3>Redirecionando para o Pagar.me...</h3>
                <p>Você será redirecionado para completar o pagamento de forma segura.</p>
                <div class="fa fa-spinner fa-spin fa-3x"></div>
                <p class="mt-3">Se o redirecionamento não funcionar automaticamente, 
                   <a href="#" onclick="submitPayment()">clique aqui</a>.</p>
            </div>
            
            <!-- Hidden form to submit payment data to Pagar.me -->
            <form id="pagarme_redirect_form" method="post" action="/payment/pagarme/redirect" style="display: none;">
                <input type="hidden" name="reference" t-att-value="reference"/>
                <input type="hidden" name="amount" t-att-value="converted_amount"/>
                <input type="hidden" name="access_token" t-att-value="access_token"/>
                <input type="hidden" name="partner_id" t-att-value="partner_id"/>
                <input type="hidden" name="currency_id" t-att-value="currency_id"/>
                <input type="hidden" name="return_url" t-att-value="return_url"/>
            </form>
        </div>
        
        <!-- Auto-redirect script -->
        <script type="text/javascript">
            function submitPayment() {
                document.getElementById('pagarme_redirect_form').submit();
            }
            
            // Auto-submit after 2 seconds
            setTimeout(function() {
                submitPayment();
            }, 2000);
        </script>
    </template>

    <template id="checkout_page" name="Pagar.me Checkout Page">
        <t t-call="website.layout">
            <div class="container mt-5">
                <div class="row justify-content-center">
                    <div class="col-md-6">
                        <div class="card">
                            <div class="card-header text-center">
                                <h3>💳 Pagar.me Checkout</h3>
                            </div>
                            <div class="card-body">
                                <div class="text-center">
                                    <h4>Resumo do Pagamento</h4>
                                    <p><strong>Referência:</strong> <span t-esc="reference"/></p>
                                    <p><strong>Valor:</strong> <span t-esc="currency.symbol"/> <span t-esc="amount"/></p>
                                    
                                    <div class="mt-4">
                                        <p>Complete o pagamento de forma segura:</p>
                                        <a href="#" class="btn btn-primary btn-lg" onclick="simulatePayment()">
                                            Pagar com Cartão de Crédito
                                        </a>
                                    </div>
                                    
                                    <div class="mt-3">
                                        <a t-attf-href="/payment/pagarme/return?reference={{reference}}&amp;status=cancel" 
                                           class="btn btn-secondary">Cancelar</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            <script type="text/javascript">
                function simulatePayment() {
                    // In real implementation, this would integrate with Pagar.me's checkout
                    // For now, simulate successful payment
                    var confirmed = confirm('Simular pagamento aprovado?');
                    if (confirmed) {
                        window.location.href = '/payment/pagarme/return?reference=<t t-esc="reference"/>&amp;status=success&amp;transaction_id=sim_' + Date.now();
                    }
                }
            </script>
        </t>
    </template>

</odoo>