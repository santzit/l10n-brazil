<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="inline_form" name="Pagar.me Inline Form">
        <div t-attf-id="o_pagarme_payment_container_{{payment_option_id or provider_id or id}}" class="o_pagarme_payment_form">
            <!-- Debug: Show available variables -->
            <div style="background: #f0f0f0; padding: 10px; margin-bottom: 10px; font-size: 12px; display: none;" id="pagarme_debug_info">
                <strong>🔍 Template Context Debug:</strong><br/>
                Reference: <span t-esc="reference"/> | Processing: <span t-esc="processing_values.get('reference', 'missing') if processing_values else 'no processing_values'"/><br/>
                Provider ID: <span t-esc="provider_id"/> | Processing: <span t-esc="processing_values.get('provider_id', 'missing') if processing_values else 'no processing_values'"/><br/>  
                Access Token: <span t-esc="access_token"/> | Processing: <span t-esc="processing_values.get('access_token', 'missing') if processing_values else 'no processing_values'"/><br/>
                Payment Option ID: <span t-esc="payment_option_id"/><br/>
                ID: <span t-esc="id"/><br/>
            </div>
            
            <!-- Hidden fields for form submission with multiple fallback options -->
            <input type="hidden" name="reference" t-att-value="reference or (processing_values.get('reference') if processing_values else '') or ''"/>
            <input type="hidden" name="provider_id" t-att-value="provider_id or (processing_values.get('provider_id') if processing_values else '') or payment_option_id or id or ''"/>
            <input type="hidden" name="access_token" t-att-value="access_token or (processing_values.get('access_token') if processing_values else '') or ''"/>
            
            <!-- Card input form -->
            <div class="card" style="margin: 15px 0; padding: 20px;">
                <h5 class="card-title">💳 Dados do Cartão de Crédito</h5>
                <div class="form-group">
                    <label for="pagarme_card_number" class="required">Número do Cartão:</label>
                    <input type="text" id="pagarme_card_number" name="pagarme_card_number" 
                           placeholder="0000 0000 0000 0000" class="form-control" 
                           maxlength="19" autocomplete="cc-number" required="true"/>
                </div>
                
                <div class="form-group">
                    <label for="pagarme_card_holder" class="required">Nome no Cartão:</label>
                    <input type="text" id="pagarme_card_holder" name="pagarme_card_holder_name"
                           placeholder="Nome conforme impresso no cartão" class="form-control" 
                           autocomplete="cc-name" required="true"/>
                </div>
                
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label for="pagarme_card_expiry" class="required">Validade:</label>
                            <input type="text" id="pagarme_card_expiry" name="pagarme_card_expiry"
                                   placeholder="MM/AA" class="form-control" 
                                   maxlength="5" autocomplete="cc-exp" required="true"/>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label for="pagarme_card_cvv" class="required">CVV:</label>
                            <input type="text" id="pagarme_card_cvv" name="pagarme_card_cvv"
                                   placeholder="123" class="form-control" 
                                   maxlength="4" autocomplete="cc-csc" required="true"/>
                        </div>
                    </div>
                </div>
                
                <!-- Hidden fields for expiry date components -->
                <input type="hidden" id="pagarme_card_exp_month" name="pagarme_card_exp_month"/>
                <input type="hidden" id="pagarme_card_exp_year" name="pagarme_card_exp_year"/>
            </div>
        </div>
    </template>

</odoo>