<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="inline_form" name="Pagar.me Inline Form">
        <div t-attf-id="o_pagarme_payment_container_{{provider_id}}" class="o_pagarme_payment_form">
            <!-- Debug: Show if template is rendering -->
            <div style="background: green; color: white; padding: 10px; margin: 10px; font-weight: bold;">
                ✅ PAGAR.ME TEMPLATE RENDERED! ID: <span t-esc="provider_id"/>
            </div>
            <!-- Basic form fields -->
            <input type="text" id="pagarme_card_number" placeholder="Número do cartão" class="form-control"/>
        </div>
    </template>

</odoo>