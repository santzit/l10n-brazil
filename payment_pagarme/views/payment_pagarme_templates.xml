<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="inline_form" name="Pagar.me Inline Form">
        <!-- Minimal inline form template exactly like Adyen -->
        <div t-attf-id="o_pagarme_payment_container_{{provider_id}}" class="o_pagarme_payment_form">
            
            <!-- Critical debug: Show if template is rendering -->
            <div style="background: red; color: white; padding: 5px; margin: 5px; font-weight: bold;">
                TEMPLATE RENDERED! Provider ID: <span t-esc="provider_id"/>
            </div>
            
            <!-- Minimal payment form -->
            <input type="text" id="pagarme_card_number" name="pagarme_card_number" placeholder="Número do cartão" class="form-control mb-2"/>
            <input type="text" id="pagarme_card_holder_name" name="pagarme_card_holder_name" placeholder="Nome no cartão" class="form-control mb-2"/>
            <input type="text" id="pagarme_card_cvv" name="pagarme_card_cvv" placeholder="CVV" class="form-control"/>
            
        </div>
    </template>

</odoo>