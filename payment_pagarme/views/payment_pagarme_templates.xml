<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="inline_form" name="Pagar.me Inline Form">
        <div t-attf-id="o_pagarme_payment_container_{{payment_option_id or provider_id or id}}" class="o_pagarme_payment_form">
            <!-- Debug information with multiple variable attempts -->
            <div style="background: red; color: white; padding: 15px; margin: 10px; font-weight: bold; border: 3px solid yellow;">
                🔍 PAGAR.ME TEMPLATE DEBUG INFO
                <br/>📋 Available variables:
                <br/>- payment_option_id: <span t-esc="payment_option_id"/>
                <br/>- provider_id: <span t-esc="provider_id"/>  
                <br/>- id: <span t-esc="id"/>
                <br/>🎯 Using container ID: o_pagarme_payment_container_<span t-esc="payment_option_id or provider_id or id"/>
            </div>
            <!-- Card input fields -->
            <div class="form-group">
                <label for="pagarme_card_number">Número do Cartão:</label>
                <input type="text" id="pagarme_card_number" placeholder="0000 0000 0000 0000" class="form-control"/>
            </div>
            <div class="form-group">
                <label for="pagarme_card_holder">Nome no Cartão:</label>
                <input type="text" id="pagarme_card_holder" placeholder="Nome conforme impresso no cartão" class="form-control"/>
            </div>
            <div class="row">
                <div class="col-md-6">
                    <label for="pagarme_card_expiry">Validade:</label>
                    <input type="text" id="pagarme_card_expiry" placeholder="MM/AA" class="form-control"/>
                </div>
                <div class="col-md-6">
                    <label for="pagarme_card_cvv">CVV:</label>
                    <input type="text" id="pagarme_card_cvv" placeholder="123" class="form-control"/>
                </div>
            </div>
        </div>
    </template>

</odoo>