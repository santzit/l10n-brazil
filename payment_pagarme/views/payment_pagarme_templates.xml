<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="inline_form" name="Pagar.me Inline Form">
        <div t-attf-id="o_pagarme_payment_container_{{provider_id}}" class="o_pagarme_payment_form">
            <!-- Debug: Show available variables -->
            <div style="background: #f0f0f0; padding: 10px; margin-bottom: 10px; font-size: 12px;" id="pagarme_debug_info">
                <strong>🔍 Template Context Debug:</strong><br/>
                <!-- Direct context variables -->
                Reference: <span t-esc="reference or 'MISSING'"/> | Transaction ID: <span t-esc="transaction_id or 'MISSING'"/><br/>
                Provider ID: <span t-esc="provider_id or 'MISSING'"/> | Processing: <span t-esc="'has processing_values' if processing_values else 'no processing_values'"/><br/>
                Access Token: <span t-esc="access_token[:10] + '...' if access_token else 'MISSING'"/><br/>
                Form Action: <span t-esc="form_action or 'MISSING'"/><br/>
                
                <!-- Transaction object access -->
                Transaction Object: <span t-esc="'YES' if tx else 'MISSING'"/><br/>
                <t t-if="tx">
                    TX Reference: <span t-esc="tx.reference or 'EMPTY'"/> | TX ID: <span t-esc="tx.id or 'EMPTY'"/><br/>
                    TX Provider ID: <span t-esc="tx.provider_id.id if tx.provider_id else 'EMPTY'"/><br/>
                    TX Access Token: <span t-esc="(tx.access_token[:10] + '...') if tx.access_token else 'EMPTY'"/><br/>
                </t>
                
                <!-- Additional debugging to see what variables are actually available -->
                Available Context Keys: <span t-esc="', '.join([k for k in globals().keys() if not k.startswith('_')])[:200] + '...' if globals() else 'No globals'"</span><br/>
                
                <!-- Final values that will be used in hidden fields -->
                <strong>📋 Final Field Values:</strong><br/>
                Hidden Reference: <span t-esc="reference or (tx.reference if tx else '') or transaction_id or 'WILL_BE_EMPTY'"/><br/>
                Hidden Provider ID: <span t-esc="provider_id or (tx.provider_id.id if tx and tx.provider_id else '') or 'WILL_BE_EMPTY'"/><br/>
                Hidden Access Token: <span t-esc="(access_token or (tx.access_token if tx else '') or '')[:10] + '...' if (access_token or (tx.access_token if tx else '')) else 'WILL_BE_EMPTY'"/><br/>
            </div>
            
            <!-- Hidden fields with comprehensive fallback mechanisms following standard Odoo patterns -->
            <input type="hidden" name="reference" 
                   t-att-value="reference or (processing_values.get('reference') if processing_values else '') or (tx.reference if tx else '') or transaction_id or ''"/>
            <input type="hidden" name="provider_id" 
                   t-att-value="provider_id or (processing_values.get('provider_id') if processing_values else '') or (tx.provider_id.id if tx and tx.provider_id else '') or ''"/>
            <input type="hidden" name="access_token" 
                   t-att-value="access_token or (processing_values.get('access_token') if processing_values else '') or (tx.access_token if tx else '') or ''"/>
            
            <!-- Card input form -->
            <div class="card" style="margin: 15px 0; padding: 20px;">
                <h5 class="card-title">💳 Dados do Cartão de Crédito</h5>
                <div class="form-group">
                    <label for="pagarme_card_number" class="required">Número do Cartão:</label>
                    <input type="text" id="pagarme_card_number" name="pagarme_card_number" 
                           placeholder="0000 0000 0000 0000" class="form-control" 
                           maxlength="19" autocomplete="cc-number" required="true"/>
                </div>
                
                <div class="form-group">
                    <label for="pagarme_card_holder" class="required">Nome no Cartão:</label>
                    <input type="text" id="pagarme_card_holder" name="pagarme_card_holder_name"
                           placeholder="Nome conforme impresso no cartão" class="form-control" 
                           autocomplete="cc-name" required="true"/>
                </div>
                
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label for="pagarme_card_expiry" class="required">Validade:</label>
                            <input type="text" id="pagarme_card_expiry" name="pagarme_card_expiry"
                                   placeholder="MM/AA" class="form-control" 
                                   maxlength="5" autocomplete="cc-exp" required="true"/>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label for="pagarme_card_cvv" class="required">CVV:</label>
                            <input type="text" id="pagarme_card_cvv" name="pagarme_card_cvv"
                                   placeholder="123" class="form-control" 
                                   maxlength="4" autocomplete="cc-csc" required="true"/>
                        </div>
                    </div>
                </div>
                
                <!-- Hidden fields for expiry date components -->
                <input type="hidden" id="pagarme_card_exp_month" name="pagarme_card_exp_month"/>
                <input type="hidden" id="pagarme_card_exp_year" name="pagarme_card_exp_year"/>
            </div>
        </div>
    </template>

</odoo>