<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="inline_form" name="Pagar.me Inline Form">
        <div t-attf-id="o_pagarme_payment_container_{{provider_id}}" class="o_pagarme_payment_form">
            <!-- Debug information to verify context variables -->
            <div style="background: #f8f9fa; padding: 10px; margin-bottom: 15px; font-size: 12px; border-radius: 5px;" id="pagarme_debug_info">
                <strong>🔍 Pagar.me Form Debug:</strong><br/>
                Reference: <span t-esc="reference or 'MISSING'"/><br/>
                Provider ID: <span t-esc="provider_id or 'MISSING'"/><br/>
                Access Token: <span t-esc="('Present: ' + str(access_token)[:20] + '...' if access_token else 'MISSING')"/><br/>
                Amount: <span t-esc="amount or 'MISSING'"/><br/>
                TX Object: <span t-esc="('Present' if tx else 'MISSING')"/><br/>
                Encryption Key: <span t-esc="('Present' if encryption_key else 'MISSING')"/><br/>
            </div>
            
            <!-- Hidden fields for transaction data -->
            <input type="hidden" name="reference" t-att-value="reference or ''"/>
            <input type="hidden" name="provider_id" t-att-value="provider_id or ''"/>
            <input type="hidden" name="access_token" t-att-value="access_token or ''"/>
            <input type="hidden" name="encryption_key" t-att-value="encryption_key or ''"/>
            
            <!-- Card input form -->
            <div class="card" style="margin: 15px 0; padding: 20px;">
                <h5 class="card-title">💳 Dados do Cartão de Crédito</h5>
                <div class="form-group">
                    <label for="pagarme_card_number" class="required">Número do Cartão:</label>
                    <input type="text" id="pagarme_card_number" name="pagarme_card_number" 
                           placeholder="0000 0000 0000 0000" class="form-control" 
                           maxlength="19" autocomplete="cc-number" required="true"/>
                </div>
                
                <div class="form-group">
                    <label for="pagarme_card_holder_name" class="required">Nome no Cartão:</label>
                    <input type="text" id="pagarme_card_holder_name" name="pagarme_card_holder_name"
                           placeholder="Nome conforme impresso no cartão" class="form-control" 
                           autocomplete="cc-name" required="true"/>
                </div>
                
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label for="pagarme_card_expiry" class="required">Validade:</label>
                            <input type="text" id="pagarme_card_expiry" name="pagarme_card_expiry"
                                   placeholder="MM/AA" class="form-control" 
                                   maxlength="5" autocomplete="cc-exp" required="true"/>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label for="pagarme_card_cvv" class="required">CVV:</label>
                            <input type="text" id="pagarme_card_cvv" name="pagarme_card_cvv"
                                   placeholder="123" class="form-control" 
                                   maxlength="4" autocomplete="cc-csc" required="true"/>
                        </div>
                    </div>
                </div>
                
                <div class="form-group">
                    <label for="pagarme_installments">Parcelamento:</label>
                    <select id="pagarme_installments" name="pagarme_installments" class="form-control">
                        <option value="1">1x sem juros</option>
                        <!-- Additional installment options will be loaded dynamically -->
                    </select>
                </div>
            </div>
        </div>
        
        <!-- Inline JavaScript for form enhancements -->
        <script type="text/javascript">
        (function () {
            'use strict';
            
            console.log('🚀 Pagar.me payment form loading...');

            function formatCardNumber(input) {
                let value = input.value.replace(/\s/g, '').replace(/\D/g, '');
                value = value.replace(/(\d{4})(?=\d)/g, '$1 ');
                input.value = value;
            }

            function formatExpiry(input) {
                let value = input.value.replace(/\D/g, '');
                if (value.length >= 2) {
                    value = value.substring(0, 2) + '/' + value.substring(2, 4);
                }
                input.value = value;
            }

            function formatCvv(input) {
                input.value = input.value.replace(/\D/g, '');
            }

            // Initialize when DOM is ready
            document.addEventListener('DOMContentLoaded', function() {
                // Card number formatting
                const cardNumberInput = document.getElementById('pagarme_card_number');
                if (cardNumberInput) {
                    cardNumberInput.addEventListener('input', function(e) {
                        formatCardNumber(e.target);
                    });
                }

                // Expiry formatting  
                const expiryInput = document.getElementById('pagarme_card_expiry');
                if (expiryInput) {
                    expiryInput.addEventListener('input', function(e) {
                        formatExpiry(e.target);
                    });
                }

                // CVV formatting
                const cvvInput = document.getElementById('pagarme_card_cvv');
                if (cvvInput) {
                    cvvInput.addEventListener('input', function(e) {
                        formatCvv(e.target);
                    });
                }

                console.log('✅ Pagar.me form enhancements initialized');
            });

        })();
        </script>
    </template>

</odoo>