<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Note: For Pagar.me redirect checkout, inline form is not needed -->
    <!-- Payment is processed via redirect to Pagar.me's secure checkout page -->
    <template id="inline_form" name="Pagar.me Inline Form (Not Used for Redirect)">
        <div class="o_pagarme_payment_form">
            <div class="alert alert-info">
                <strong>Pagamento Seguro via Pagar.me</strong><br/>
                Você será redirecionado para completar o pagamento de forma segura no Pagar.me.
            </div>
        </div>
    </template>

    <template id="redirect_form" name="Pagar.me Redirect Form">
        <div class="o_pagarme_redirect_form">
            <div class="text-center">
                <h3>Redirecionando para o Pagar.me...</h3>
                <p>Você será redirecionado para completar o pagamento de forma segura.</p>
                <div class="fa fa-spinner fa-spin fa-3x"></div>
                <p class="mt-3">Se o redirecionamento não funcionar automaticamente, 
                   <a t-att-href="api_url" target="_self">clique aqui</a>.</p>
            </div>
        </div>
        
        <!-- Auto-redirect script -->
        <script type="text/javascript">
            // Auto-redirect immediately to Pagar.me checkout
            window.location.href = '<t t-esc="api_url"/>';
        </script>
    </template>

    <template id="checkout_page" name="Pagar.me Checkout Page">
        <t t-call="website.layout">
            <div class="container mt-5">
                <div class="row justify-content-center">
                    <div class="col-md-6">
                        <div class="card">
                            <div class="card-header text-center">
                                <h3>💳 Pagar.me Checkout</h3>
                            </div>
                            <div class="card-body">
                                <div class="text-center">
                                    <h4>Resumo do Pagamento</h4>
                                    <p><strong>Referência:</strong> <span t-esc="reference"></span></p>
                                    <p><strong>Valor:</strong> <span t-esc="currency.symbol"></span> <span t-esc="amount"></span></p>
                                    
                                    <div class="mt-4">
                                        <p>Complete o pagamento de forma segura:</p>
                                        <a href="#" class="btn btn-primary btn-lg" onclick="simulatePayment()">
                                            Pagar com Cartão de Crédito
                                        </a>
                                    </div>
                                    
                                    <div class="mt-3">
                                        <a t-attf-href="/payment/pagarme/return?reference={{reference}}&amp;status=cancel" 
                                           class="btn btn-secondary">Cancelar</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            <script type="text/javascript">
                function simulatePayment() {
                    // In real implementation, this would integrate with Pagar.me's checkout
                    // For now, simulate successful payment
                    var confirmed = confirm('Simular pagamento aprovado?');
                    if (confirmed) {
                        window.location.href = '/payment/pagarme/return?reference=<t t-esc="reference"/>&amp;status=success&amp;transaction_id=sim_' + Date.now();
                    }
                }
            </script>
        </t>
    </template>

    <template id="payment_error" name="Pagar.me Payment Error">
        <t t-call="website.layout">
            <div class="container mt-5">
                <div class="row justify-content-center">
                    <div class="col-md-6">
                        <div class="card border-danger">
                            <div class="card-header bg-danger text-white text-center">
                                <h3><i class="fa fa-exclamation-triangle"></i> Erro no Pagamento</h3>
                            </div>
                            <div class="card-body">
                                <div class="text-center">
                                    <h4>Não foi possível processar o pagamento</h4>
                                    <p class="text-muted">Referência: <span t-esc="reference"></span></p>
                                    
                                    <div class="alert alert-danger mt-3">
                                        <strong>Erro:</strong> <span t-esc="error_message"></span>
                                    </div>
                                    
                                    <div class="mt-4">
                                        <p>Por favor, tente novamente ou entre em contato com o suporte.</p>
                                        <a href="/payment/process" class="btn btn-primary">
                                            <i class="fa fa-refresh"></i> Tentar Novamente
                                        </a>
                                        <a href="/" class="btn btn-secondary ml-2">
                                            <i class="fa fa-home"></i> Voltar ao Início
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

</odoo>