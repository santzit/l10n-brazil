<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="inline_form" name="Pagar.me Inline Form">
        <div t-attf-id="o_pagarme_payment_container_{{provider_id}}" class="o_pagarme_payment_form">
            <!-- Enhanced debug information to see ALL available variables -->
            <div style="background: #f0f0f0; padding: 10px; margin-bottom: 10px; font-size: 12px;" id="pagarme_debug_info">
                <strong>🔍 Pagar.me Template Debug:</strong><br/>
                <!-- Check direct context variables -->
                Reference: <span t-esc="reference or 'MISSING'"/><br/>
                Provider ID: <span t-esc="provider_id or 'MISSING'"/><br/>
                Access Token: <span t-esc="('Present: ' + access_token[:20] + '...') if access_token else 'MISSING'"/><br/>
                Transaction ID: <span t-esc="transaction_id or 'MISSING'"/><br/>
                Amount: <span t-esc="amount or 'MISSING'"/><br/>
                Currency: <span t-esc="currency or 'MISSING'"/><br/>
                
                <!-- Check transaction object -->
                TX Object: <span t-esc="'Present' if tx else 'MISSING'"/><br/>
                <t t-if="tx">
                    TX Ref: <span t-esc="tx.reference or 'EMPTY'"/><br/>
                    TX Provider: <span t-esc="tx.provider_id.id if tx.provider_id else 'EMPTY'"/><br/>
                    TX Access Token: <span t-esc="('Present' if tx.access_token else 'MISSING') if hasattr(tx, 'access_token') else 'NO_ATTR'"/><br/>
                </t>
                
                <!-- Check processing_values -->
                Processing Values: <span t-esc="'Present' if processing_values else 'MISSING'"/><br/>
                <t t-if="processing_values">
                    Processing Ref: <span t-esc="processing_values.get('reference') or 'EMPTY'"/><br/>
                    Processing Provider: <span t-esc="processing_values.get('provider_id') or 'EMPTY'"/><br/>
                </t>
            </div>
            
            <!-- Multiple fallback strategies for critical hidden fields -->
            <input type="hidden" name="reference" 
                   t-att-value="reference or (tx.reference if tx else '') or (processing_values.get('reference') if processing_values else '') or ''"/>
            
            <input type="hidden" name="provider_id" 
                   t-att-value="provider_id or (tx.provider_id.id if tx and tx.provider_id else '') or (processing_values.get('provider_id') if processing_values else '') or ''"/>
            
            <input type="hidden" name="access_token" 
                   t-att-value="access_token or (tx.access_token if tx and hasattr(tx, 'access_token') else '') or (processing_values.get('access_token') if processing_values else '') or ''"/>
            
            <!-- Card input form -->
            <div class="card" style="margin: 15px 0; padding: 20px;">
                <h5 class="card-title">💳 Dados do Cartão de Crédito</h5>
                <div class="form-group">
                    <label for="pagarme_card_number" class="required">Número do Cartão:</label>
                    <input type="text" id="pagarme_card_number" name="pagarme_card_number" 
                           placeholder="0000 0000 0000 0000" class="form-control" 
                           maxlength="19" autocomplete="cc-number" required="true"/>
                </div>
                
                <div class="form-group">
                    <label for="pagarme_card_holder" class="required">Nome no Cartão:</label>
                    <input type="text" id="pagarme_card_holder" name="pagarme_card_holder_name"
                           placeholder="Nome conforme impresso no cartão" class="form-control" 
                           autocomplete="cc-name" required="true"/>
                </div>
                
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label for="pagarme_card_expiry" class="required">Validade:</label>
                            <input type="text" id="pagarme_card_expiry" name="pagarme_card_expiry"
                                   placeholder="MM/AA" class="form-control" 
                                   maxlength="5" autocomplete="cc-exp" required="true"/>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label for="pagarme_card_cvv" class="required">CVV:</label>
                            <input type="text" id="pagarme_card_cvv" name="pagarme_card_cvv"
                                   placeholder="123" class="form-control" 
                                   maxlength="4" autocomplete="cc-csc" required="true"/>
                        </div>
                    </div>
                </div>
                
                <!-- Hidden fields for expiry date components -->
                <input type="hidden" id="pagarme_card_exp_month" name="pagarme_card_exp_month"/>
                <input type="hidden" id="pagarme_card_exp_year" name="pagarme_card_exp_year"/>
            </div>
        </div>
    </template>

</odoo>