<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Pagar.me Inline Payment Form Template -->
    <template id="inline_form" name="Pagar.me Inline Form">
        <div t-attf-id="o_pagarme_payment_container_{{provider.id}}" 
             t-att-data-provider-id="provider.id" 
             class="o_pagarme_payment_form">
            
            <!-- Pagar.me Branding -->
            <div class="text-center mb-3">
                <img src="/payment_pagarme/static/src/img/pagarme-icon.png" alt="Pagar.me" class="payment-provider-logo" style="height: 40px; margin-bottom: 10px;"/>
                <p class="text-muted small">Pagamento seguro processado pela Pagar.me</p>
            </div>
            
            <!-- Payment Form Container -->
            <div class="o_pagarme_form_container">
                
                <!-- Customer Information -->
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label for="pagarme_customer_name" class="form-label">Nome Completo *</label>
                        <input type="text" class="form-control" id="pagarme_customer_name" 
                               name="pagarme_customer_name" required="required"/>
                    </div>
                    <div class="col-md-6">
                        <label for="pagarme_customer_document" class="form-label">CPF/CNPJ *</label>
                        <input type="text" class="form-control" id="pagarme_customer_document" 
                               name="pagarme_customer_document" required="required"
                               placeholder="000.000.000-00"/>
                        <div class="invalid-feedback">CPF/CNPJ inválido</div>
                    </div>
                </div>
                
                <!-- Credit Card Information -->
                <div class="row mb-3">
                    <div class="col-12">
                        <label for="pagarme_card_number" class="form-label">Número do Cartão *</label>
                        <input type="text" class="form-control" id="pagarme_card_number" 
                               name="pagarme_card_number" required="required"
                               placeholder="0000 0000 0000 0000"/>
                    </div>
                </div>
                
                <div class="row mb-3">
                    <div class="col-12">
                        <label for="pagarme_card_holder_name" class="form-label">Nome no Cartão *</label>
                        <input type="text" class="form-control" id="pagarme_card_holder_name" 
                               name="pagarme_card_holder_name" required="required"
                               placeholder="Nome como está no cartão"/>
                    </div>
                </div>
                
                <div class="row mb-3">
                    <div class="col-md-4">
                        <label for="pagarme_card_exp_month" class="form-label">Mês *</label>
                        <select class="form-control" id="pagarme_card_exp_month" 
                                name="pagarme_card_exp_month" required="required">
                            <option value="">Mês</option>
                            <option value="01">01</option>
                            <option value="02">02</option>
                            <option value="03">03</option>
                            <option value="04">04</option>
                            <option value="05">05</option>
                            <option value="06">06</option>
                            <option value="07">07</option>
                            <option value="08">08</option>
                            <option value="09">09</option>
                            <option value="10">10</option>
                            <option value="11">11</option>
                            <option value="12">12</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label for="pagarme_card_exp_year" class="form-label">Ano *</label>
                        <select class="form-control" id="pagarme_card_exp_year" 
                                name="pagarme_card_exp_year" required="required">
                            <option value="">Ano</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label for="pagarme_card_cvv" class="form-label">CVV *</label>
                        <input type="text" class="form-control" id="pagarme_card_cvv" 
                               name="pagarme_card_cvv" required="required"
                               placeholder="123" maxlength="4"/>
                    </div>
                </div>
                
                <!-- Installments -->
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label for="pagarme_installments" class="form-label">Parcelas *</label>
                        <select class="form-control" id="pagarme_installments" 
                                name="pagarme_installments" required="required">
                            <option value="1">1x sem juros</option>
                        </select>
                    </div>
                </div>
                
                <!-- Security info -->
                <div class="text-center mt-3">
                    <small class="text-muted">
                        <i class="fa fa-shield-alt me-1"></i>
                        Seus dados estão protegidos com criptografia SSL
                    </small>
                </div>
                
            </div>
        </div>
    </template>

</odoo>