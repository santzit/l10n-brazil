<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <record id="payment_provider_pagarme" model="payment.provider">
        <field name="name">Pagar.me</field>
        <field name="code">pagarme</field>
        <field name="state">disabled</field>
        <field name="redirect_form_view_id" ref="payment_pagarme.redirect_form"/>
        <field name="allow_tokenization">False</field>
        <field name="support_tokenization">False</field>
        <field name="support_express_checkout">True</field>
        <field name="image_128" type="base64" file="payment_pagarme/static/description/icon.png"/>
        <field name="display_as">💳 Pagar.me</field>
        <field name="pre_msg">Pague com segurança usando seu cartão de crédito através do Pagar.me.</field>
    </record>

</odoo>