<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Account Payment Order Views for Pagar.me -->
    <record id="account_payment_order_form_pagarme" model="ir.ui.view">
        <field name="name">account.payment.order.form.pagarme</field>
        <field name="model">account.payment.order</field>
        <field name="inherit_id" ref="account_payment_order.account_payment_order_form"/>
        <field name="arch" type="xml">
            
            <!-- Add Pagar.me info in header -->
            <xpath expr="//field[@name='state']" position="after">
                <field name="pagarme_processor" invisible="1"/>
                <field name="pagarme_batch_id" readonly="1" 
                       attrs="{'invisible': [('pagarme_processor', '=', False)]}"/>
                <field name="pagarme_batch_status" readonly="1"
                       attrs="{'invisible': [('pagarme_processor', '=', False)]}"/>
            </xpath>
            
            <!-- Add Pagar.me buttons -->
            <xpath expr="//button[@name='action_uploaded_cancel']" position="after">
                <button name="action_pagarme_check_status" 
                        string="Check Status" 
                        type="object" 
                        class="btn-primary"
                        attrs="{'invisible': ['|', ('pagarme_processor', '=', False), ('state', 'not in', ['uploaded', 'done'])]}"/>
            </xpath>
            
            <!-- Add Pagar.me tab -->
            <xpath expr="//notebook" position="inside">
                <page name="pagarme_config" string="Pagar.me Configuration" 
                      attrs="{'invisible': [('pagarme_processor', '=', False)]}">
                    
                    <group>
                        <group string="Payment Configuration">
                            <field name="pagarme_payment_method"/>
                        </group>
                        <group string="Split Rules">
                            <field name="pagarme_split_rules" widget="text" 
                                   placeholder='{"rules": [{"recipient_id": "re_xxx", "percentage": 80}]}'/>
                        </group>
                    </group>
                    
                </page>
            </xpath>
            
        </field>
    </record>

    <!-- Payment Transaction Tree View -->
    <record id="payment_transaction_tree_pagarme" model="ir.ui.view">
        <field name="name">payment.transaction.tree.pagarme</field>
        <field name="model">payment.transaction</field>
        <field name="inherit_id" ref="payment.payment_transaction_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='provider_id']" position="after">
                <field name="pagarme_transaction_id" optional="hide"/>
                <field name="pagarme_payment_method" optional="show"/>
            </xpath>
        </field>
    </record>

    <!-- Payment Transaction Form View -->
    <record id="payment_transaction_form_pagarme" model="ir.ui.view">
        <field name="name">payment.transaction.form.pagarme</field>
        <field name="model">payment.transaction</field>
        <field name="inherit_id" ref="payment.payment_transaction_view_form"/>
        <field name="arch" type="xml">
            
            <!-- Add Pagar.me tab -->
            <xpath expr="//notebook" position="inside">
                <page name="pagarme_details" string="Pagar.me Details" 
                      attrs="{'invisible': [('provider_code', '!=', 'pagarme')]}">
                    
                    <group>
                        <group string="Transaction Info">
                            <field name="pagarme_transaction_id" readonly="1"/>
                            <field name="pagarme_charge_id" readonly="1"/>
                            <field name="pagarme_payment_method" readonly="1"/>
                        </group>
                        <group string="Fraud Analysis">
                            <field name="pagarme_fraud_status" readonly="1"/>
                            <field name="pagarme_fraud_score" readonly="1"/>
                        </group>
                    </group>
                    
                    <group name="pagarme_credit_card_group" string="Credit Card Details"
                           attrs="{'invisible': [('pagarme_payment_method', '!=', 'credit_card')]}">
                        <group>
                            <field name="pagarme_card_brand" readonly="1"/>
                            <field name="pagarme_card_last_digits" readonly="1"/>
                        </group>
                        <group>
                            <field name="pagarme_installments" readonly="1"/>
                            <field name="pagarme_acquirer_code" readonly="1"/>
                            <field name="pagarme_acquirer_message" readonly="1"/>
                        </group>
                    </group>
                    
                    <group name="pagarme_boleto_group" string="Boleto Details"
                           attrs="{'invisible': [('pagarme_payment_method', '!=', 'boleto')]}">
                        <group>
                            <field name="pagarme_boleto_url" readonly="1" widget="url"/>
                            <field name="pagarme_boleto_barcode" readonly="1"/>
                        </group>
                        <group>
                            <field name="pagarme_boleto_due_date" readonly="1"/>
                        </group>
                    </group>
                    
                    <group name="pagarme_pix_group" string="PIX Details"
                           attrs="{'invisible': [('pagarme_payment_method', '!=', 'pix')]}">
                        <group>
                            <field name="pagarme_pix_qr_code_url" readonly="1" widget="url"/>
                            <field name="pagarme_pix_expiration_date" readonly="1"/>
                        </group>
                        <group>
                            <field name="pagarme_pix_qr_code" readonly="1" widget="text"/>
                        </group>
                    </group>
                    
                    <group string="Gateway Response">
                        <field name="pagarme_gateway_response" readonly="1" widget="text"/>
                    </group>
                    
                </page>
            </xpath>
            
        </field>
    </record>

</odoo>