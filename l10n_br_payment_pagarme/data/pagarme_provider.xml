<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <record id="payment_provider_pagarme" model="payment.provider">
        <field name="name">Pagar.me</field>
        <field name="code">pagarme</field>
        <field name="state">disabled</field>
        <field name="inline_form_view_id" ref="l10n_br_payment_pagarme.inline_form"/>
        <field name="redirect_form_view_id"></field>
        <field name="display_as">💳 Pagar.me</field>
        <field name="pre_msg">Preencha os dados do seu cartão de crédito abaixo.</field>
        <field name="done_msg">Seu pagamento foi processado com sucesso.</field>
        <field name="pending_msg">Seu pagamento está sendo processado. Você receberá uma confirmação em breve.</field>
        <field name="cancel_msg">Seu pagamento foi cancelado.</field>
        <field name="support_tokenization">False</field>
        <field name="support_express_checkout">False</field>
        <field name="support_refund">partial</field>
        <field name="image_128" type="base64" file="l10n_br_payment_pagarme/static/description/icon.png"/>
    </record>
</odoo>
