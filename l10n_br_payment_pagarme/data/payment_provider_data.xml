<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <record id="payment.payment_provider_pagarme" model="payment.provider">
        <field name="code">pagarme</field>
        <field name="state">test</field>
        <field name="is_published">true</field>
        <field name="inline_form_view_id" ref="inline_form"/>
        <field name="token_inline_form_view_id" ref="token_inline_form"/>
        <field name="express_checkout_form_view_id" ref="express_checkout_form"/>
        <field name="allow_tokenization">true</field>
        <field name="allow_express_checkout">true</field>
        <field name="payment_method_ids"
               eval="[(6, 0, [ref('l10n_br_payment_pagarme.payment_method_pagarme')])]"
        />
    </record>

</odoo>