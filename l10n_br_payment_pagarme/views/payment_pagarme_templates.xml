<!-- views/payment_pagarme_templates.xml -->
<odoo>
    <template id="payment_pagarme_form" name="Pagar.me Payment Form">
        <div class="payment-provider-form"
             data-provider="pagarme"
             t-att-data-public-key="provider.pagarme_public_key"
             t-att-data-encryption-key="provider.pagarme_encryption_key">

            <input type="text" name="card_name" placeholder="Card Holder Name"/>
            <input type="text" name="card_number" placeholder="Card Number"/>
            <input type="text" name="card_expiration" placeholder="MMYY"/>
            <input type="text" name="card_cvv" placeholder="CVV"/>
            <input type="hidden" name="pagarme_card_token"/>
        </div>
    </template>
</odoo>
