<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Inline form template for Pagar.me payment provider -->
        <template id="inline_form" name="Pagar.me Inline Form">
            <!-- Load Pagar.me Tokenizacard.js -->
            <script type="text/javascript" src="https://checkout.pagar.me/v1/tokenizecard.js"></script>
            
            <!-- Payment form following standard Odoo payment structure -->
            <form class="o_payment_form_pagarme" method="post" action="#" data-pagarme-form="true">
                <div class="row">
                    <div class="col-md-12">
                        <div class="mb-3">
                            <label class="form-label">Nome do Portador *</label>
                            <input type="text" 
                                   name="pagarme_card_holder_name" 
                                   id="pagarme_card_holder_name"
                                   data-pagarme-checkout-element="cardholder-name"
                                   class="form-control o_payment_form_input" 
                                   placeholder="Nome completo como no cartão"
                                   autocomplete="cc-name"
                                   required="required"/>
                        </div>
                    </div>
                    <div class="col-md-12">
                        <div class="mb-3">
                            <label class="form-label">Número do Cartão *</label>
                            <input type="text" 
                                   name="pagarme_card_number" 
                                   id="pagarme_card_number"
                                   data-pagarme-checkout-element="card-number"
                                   class="form-control o_payment_form_input" 
                                   placeholder="1234 5678 9012 3456"
                                   autocomplete="cc-number"
                                   maxlength="23"
                                   required="required"/>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label">Data de Expiração *</label>
                            <div class="row">
                                <div class="col-6">
                                    <select name="pagarme_card_expiry_month" 
                                            id="pagarme_card_expiry_month" 
                                            data-pagarme-checkout-element="card-expiry-month"
                                            class="form-select o_payment_form_input" 
                                            autocomplete="cc-exp-month"
                                            required="required">
                                        <option value="">Mês</option>
                                        <option value="01">01</option>
                                        <option value="02">02</option>
                                        <option value="03">03</option>
                                        <option value="04">04</option>
                                        <option value="05">05</option>
                                        <option value="06">06</option>
                                        <option value="07">07</option>
                                        <option value="08">08</option>
                                        <option value="09">09</option>
                                        <option value="10">10</option>
                                        <option value="11">11</option>
                                        <option value="12">12</option>
                                    </select>
                                </div>
                                <div class="col-6">
                                    <select name="pagarme_card_expiry_year" 
                                            id="pagarme_card_expiry_year" 
                                            data-pagarme-checkout-element="card-expiry-year"
                                            class="form-select o_payment_form_input" 
                                            autocomplete="cc-exp-year"
                                            required="required">
                                        <option value="">Ano</option>
                                        <option value="2024">2024</option>
                                        <option value="2025">2025</option>
                                        <option value="2026">2026</option>
                                        <option value="2027">2027</option>
                                        <option value="2028">2028</option>
                                        <option value="2029">2029</option>
                                        <option value="2030">2030</option>
                                        <option value="2031">2031</option>
                                        <option value="2032">2032</option>
                                        <option value="2033">2033</option>
                                        <option value="2034">2034</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label">CVV *</label>
                            <input type="text" 
                                   name="pagarme_card_cvv" 
                                   id="pagarme_card_cvv"
                                   data-pagarme-checkout-element="card-cvv"
                                   class="form-control o_payment_form_input" 
                                   placeholder="123"
                                   autocomplete="cc-csc"
                                   maxlength="4"
                                   required="required"/>
                        </div>
                    </div>
                </div>
            </form>
        </template>
    </data>
</odoo>