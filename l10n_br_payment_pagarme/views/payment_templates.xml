<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Redirect form template for Pagar.me payment provider -->
        <template id="redirect_form" name="Pagar.me Redirect Form">
            <div class="alert alert-info">
                <i class="fa fa-info-circle"/> Você será redirecionado para o checkout seguro do Pagar.me.
            </div>
            <form method="post" t-att-action="checkout_url" target="_self">
                <input type="hidden" name="reference" t-att-value="reference"/>
                <div class="text-center">
                    <button type="submit" class="btn btn-primary btn-lg">
                        <i class="fa fa-lock"/> Pagar com Pagar.me
                    </button>
                </div>
            </form>
        </template>
    </data>
</odoo>