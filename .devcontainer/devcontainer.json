{
  "name": "OCA/l10n-brazil Dev",
  "image": "mcr.microsoft.com/devcontainers/python:3.10",
  "features": {
    "ghcr.io/devcontainers/features/postgres:1": {
      "version": "14"
    }
  },
  "postCreateCommand": "pip install -r requirements.txt",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "odoo.owly"
      ]
    }
  },
  "forwardPorts": [8069],
  "remoteUser": "vscode"
}
